# GitHub credentials used by the "Save & share" publishing flow.
# Copy this file to ".env" and fill in a real token. ".env" is git-ignored.

# Required: a GitHub token with "contents:write" on the target repo.
# Fine-grained token (recommended) or a classic token with the "repo" scope.
GITHUB_TOKEN=

# Optional: the repo that uploads/tour configs are committed to.
# Format "owner/name". Defaults to bumbeishvili/360-tour-generator.
GITHUB_REPO=bumbeishvili/360-tour-generator

# Optional: the branch to commit to. Defaults to main.
GITHUB_BRANCH=main
